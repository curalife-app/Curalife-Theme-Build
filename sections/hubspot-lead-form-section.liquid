{% schema %}
 {
    "name": "Form Section",
      "tag": "section",
      "class": "form-section",
      "disabled_on": {
        "groups": ["header", "footer"]
      },
      "settings": [
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        }  
      ],
      "blocks":[
