<section class="footer no-padding">
    <div class="container">
        <div class="menus">
            <div class="column"> 
                <div class="menu">
                    <h4>Navigation</h4>
                    {% assign navigation = section.blocks | where: 'type', 'navigation' %}
                    {% for block in navigation %}
                     <a href="{{ block.settings.nav_link }}"><p><span><i class="fa-solid fa-chevron-right"></i></span>{{ block.settings.nav_ttl }}</p></a> 
                    {% endfor %}
                </div>
            </div>
            <div class="column">
                <div class="menu">
                    <h4>Contact us</h4>
                    <a href="mailto:parnetships@curalife.com"><p><i class="icofont-email"></i> partnerships@curalife.com</p></a>
                </div>

                <div class="menu">
                    <h4>Find us on</h4>
                    <div class="social-links">
                        <a href="https://www.facebook.com/curalife"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="https://www.instagram.com/curalife"><i class="fa-brands fa-instagram"></i></a>
                        <a href="https://www.twitter.com/curalife"><i class="fa-brands fa-twitter"></i></a>
                        <a href="https://www.linkedin.com/company/curalife-ltd"><i class="fa-brands fa-linkedin"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="copyrights">© 2022 CuraLife Global</p>
            <div class="policies">
                <a class="policy" href="/pages/privacy-policy">Privacy Policy</a>
                <a class="policy" href="/pages/terms-of-service">Terms of Service</a>
            </div>
        </div>
    </div>
</section>

<style>
    .footer {
        background-color: {{ section.settings.bg_color }};
        padding: 130px 0 0 0;
    }

 
    .footer .menus {
        display: flex; 
        justify-content: space-between;
        padding-bottom: 100px;
        padding-top: 50px;
    }

    .footer .menu h4 {
        color: {{ section.settings.text_color }};
        font-size: 30px;
        margin-bottom: 10px;
    }

    .footer .menu p span {
        color: {{ section.settings.dec_color }};
        font-weight: 800;
    }

    .footer .menu a,
    .footer .menu p {
        font-family: 'DMSans';
        font-size: 17px;
        color: {{ section.settings.text_color }};
        margin-bottom: 10px;
    }

    .footer .social-links {
        display: flex;
        gap: 20px;
    }

    .footer .social-links a {
        font-size: 30px;
        color: {{ section.settings.dec_color }};
    }

    .footer .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 5px;
        padding: 15px 0;
        border-top: 1px solid {{ section.settings.brd_clr }};
    }

    .footer .policies {
        display: flex;
        gap: 15px;
    }

    .footer .policy,
    .footer .copyrights {   
        font-size: 18px;
        font-family: 'DM Sans';
        font-weight: 400;
        color: {{ section.settings.text_color }};
    }

    @media screen and (max-width: 768px){
        .footer {
            padding: 5vw 5vw 0;
        }

        .footer .menus {
            flex-direction: column;
            padding-top: 7vw;
        }

        .footer .policy {
            font-size: 2vw;
        }
    }
</style>


{% schema %}
{
  "name": "Partnerships Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#404733"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dec_color",
      "label": "Decoration Color",
      "default": "#ffb22d"
    },
    {
        "type": "color_background",
        "id": "brd_clr",
        "label": "Border Color",
        "default": "rgba(255, 255, 255, 0.25)"
    }
  
  ],
  "blocks": [
    {
      "type": "navigation",
      "name": "Navigation",
      "settings": [
        {
          "type": "url",
          "id": "nav_link",
          "label": "Navigation Link"
        },
        {
          "type": "text",
          "id": "nav_ttl",
          "label": "Navigation Title"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact Numbers",
        "settings": [
          {
            "type": "image_picker",
            "id": "flag_img",
            "label": "Country Flag Image"
          },
          {
            "type": "text",
            "id": "phone_title",
            "label": "Title"
          },
          {
            "type": "text",
            "id": "phone_number",
            "label": "Phone Number"
          }
        ]
      },
      {
        "type": "social",
        "name": "Social Media",
        "settings": [
          {
            "type": "text",
            "id": "social_icon_class",
            "label": "Social Icon Class"
          },
          {
            "id": "social_link",
            "type": "url",
            "label": "Social Icon Link"
          }
        ]
      },
      {
      "type": "payment",
      "name": "Payment Images",
      "settings": [
        {
          "type": "image_picker",
          "id": "payment_img",
          "label": "Select Payment Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partnerships Footer"
    }
  ]
}
{% endschema %}