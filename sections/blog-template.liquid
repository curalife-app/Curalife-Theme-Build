<div class="blog-page">
  <div class="container">
    <div class="mini-wrap">
      {% paginate blog.articles by 9 %}
      <div class="page-title">
        <div class="sub-title">
          <h1>{{ blog.title }}</h1>
          <p>{{ section.settings.blg_des }}</p>
        </div>

        <div class="blog-category">
          <div class="category-wrap">
            <div class="touch-scroll">
              <div class="scroll-wrap">
                <ul>
                  <li  {% if current_tags == blank  %} class="active" {% endif%} ><a href="{{ blog.url }}">All</a></li>
                  {% for tag in blog.all_tags %}
                  {% assign crTag = tag  %}
                  {% if current_tags contains crTag  %}
                  {% assign cls="active" %}
                  {% else %}
                  {% assign cls="" %}
                  {% endif %}
                  <li class="{{cls}}"  > <a href="{{ blog.url }}/tagged/{{ tag | handleize }}">{{ tag }}</a></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="article-list">
        {% for article in blog.articles %}
          {% if forloop.index <= 2 %}
            {% assign desc = true %}
          {% else %}
            {% assign desc = false %}
          {% endif %}
          {% render 'blog-card-grid', article: article, description: desc %}
        {% endfor %}
      </div>
      {%- if paginate.pages > 1 -%}
      {% assign totalPage = paginate.pages %}
          {% render 'blog-pagination', paginate: paginate, totalPage:totalPage %}
        {%- endif -%}
      {% endpaginate %}
    </div>
  </div>
</div>

{% render 'newsletter-form' %}

<style>
  .blog-page {
      padding-bottom: 50px;
  }
  .container {
      position: relative;
      width: 100%;
      height: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 15px;
  }
  .mini-wrap {
      width: 100%;
      max-width: 1230px;
      margin: 0 auto;
      padding: 0 35px;
  }
  .page-title {
      margin-top: 3%;
      padding: 27px 0;
  }

  @media screen and (max-width: 1590px) {
    .mini-wrap {
        max-width: 1110px;
    }
    .page-title {
        margin-top: 3%;
        padding: 23px 0;
    }
  }

  @media screen and (max-width: 1430px) {
    .mini-wrap {
        max-width: 990px;
    }
  }

  @media screen and (max-width: 1270px) {
    .mini-wrap {
        max-width: 798px;
    }
    .page-title {
        margin-top: 2%;
    }
  }
  
  
  

  @media screen and (max-width: 768px){
    .blog-page {
        padding-bottom: 100px;
    }
    .page-title {
        padding: 15px 0;
    }
  }
  
</style>

{% schema %}
  {
    "name": "Blog",
    "settings": [
      {
        "type": "text",
        "id": "blg_des",
        "label": "Blog Description",
        "default": "Enter Blog Description"
      },
      {
        "type": "image_picker",
        "id": "authr_blgimg",
        "label": "Select Author Image"
      }
    ]
  }
{% endschema %}