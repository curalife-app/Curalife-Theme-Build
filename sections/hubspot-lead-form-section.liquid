          ]
        },
        {
          "name":"Category Image 2",
          "type":"category_image2",
          "settings":[
            {
              "type":"image_picker",
              "id":"big_image",
              "label":"Image 2"
            },
            {
              "type":"text",
              "id":"category_title",
              "label":"Category Title"
            },
            {
              "type":"text",
              "id":"category_description",
              "label":"Category Description"
            }
          ]
        }
      ],
      "presets": [
        {
          "name": "Ingredients Section"
        }
      ]
    }
{% endschema %}