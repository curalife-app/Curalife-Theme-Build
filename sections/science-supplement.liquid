
  <div class="suppliments">
     <div class="container" >
      <div id="button-container">
          <button id="button1" class="active" onclick="showScreen('screen1')">Screen 1</button>
          <button id="button2" onclick="showScreen('screen2')">Screen 2</button>
      </div>

      <div id="screen1" class="screen">
          <h1>Screen 1</h1>
      </div>

      <div id="screen2" class="screen" style="display:none">
          <h1>Screen 2</h1>
      </div>
    
     </div>
  </div>

<style>
  .container {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }
</style>

<style>
    #button-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 10px;
        background-color: #f5f5f5;
    }

    button {
        padding: 10px;
        margin: 0 10px;
        background-color: #ddd;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

    button.active {
        background-color: #aaa;
        color: #fff;
    }


</style>
  

{% schema %}
{
    "name": "Suppliments",
    "tag": "section",
    "class": "suppliments",
    "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
    },
   
     "blocks": [
        {
          "type": "slides",
          "name": "Slides",
          "settings": [
              {
                  "type": "image_picker",
                  "id": "image",
                  "label": "Image"
              },
              {
                  "type": "text",
                  "id": "title",
                  "label": "Title"
              },

              {
                  "type": "richtext",
                  "id": "content",
                  "label": "Content"
              }

          ]
        }
      ],
    "presets": [{
        "name": "Suppliments"
    }]
}
{% endschema %}


<script>
   function showScreen(screenId) {
       var screens = document.getElementsByClassName("screen");
       for (var i = 0; i < screens.length; i++) {
           screens[i].style.display = "none";
       }
       document.getElementById(screenId).style.display = "flex";

       var buttons = document.getElementsByTagName("button");
       for (var i = 0; i < buttons.length; i++) {
           if (buttons[i].id == "button1" && screenId == "screen1") {
               buttons[i].classList.add("active");
           } else if (buttons[i].id == "button2" && screenId == "screen2") {
               buttons[i].classList.add("active");
           } else {
               buttons[i].classList.remove("active");
           }
       }
   }
    
</script>






 