



<div  class="grey-bg offset-top bottom-line">
  <div class="container">
    <div class="white-bg">
      <div class="mini-wrap">
        <div class="subscribe-section">

        </div>
      </div>
    </div>
  </div>
</div>


<style>
    .offset-top, .bottom-line {
        position: relative;
        z-index: 3;
    }

    .bottom-line:after {
        content: "";
        padding-top: 90px;
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: -1;
        background: #404733;
        pointer-events: none;
    }


    .container {
        position: relative;
        width: 100%;
        height: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 15px;
    }

    .mini-wrap {
        width: 100%;
        max-width: 1230px;
        margin: 0 auto;
        padding: 0 35px;
    }


    @media screen and (max-width: 768px){
        .mini-wrap {
            max-width: 798px;
        }
    }
    
</style>








{% schema %}
 {
    "name": "Form Section",
      "tag": "section",
      "class": "form-section",
      "disabled_on": {
        "groups": ["header", "footer"]
      },
      "settings": [
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color"
        }  
      ],
      "blocks":[
        {
          "name":"Form Block",
          "type":"category_image",
          "settings":[
            {
              "type":"image_picker",
              "id":"small_image",
              "label":"Image 1"
            }
          ]
        },
        {
          "name":"Category Image 2",
          "type":"category_image2",
          "settings":[
            {
              "type":"image_picker",
              "id":"big_image",
              "label":"Image 2"
            },
            {
              "type":"text",
              "id":"category_title",
              "label":"Category Title"
            },
            {
              "type":"text",
              "id":"category_description",
              "label":"Category Description"
            }
          ]
        }
      ],
      "presets": [
        {
          "name": "Ingredients Section"
        }
      ]
    }
{% endschema %}