
<div class="dna-section">
    <div class="container">
        <div class="dna-title">{{ section.settings.title }}</div>
        <div class="dna-section-text">{{ section.settings.subtitle }}</div>
        <div class="text-about">
         {{ section.settings.main_content }}
        </div>
    </div>
    <img class="dna-img" src="{{ section.settings.image | image_url }}" width="956" height="658" alt="">
</div>


<style>
    .dna-section {
        position: relative;
        padding: 20px 0;
        overflow: hidden;
        max-height: 660px;
    }

    .dna-img {
        position: absolute;
        bottom: 0;
        right: 0;
       
    }

   
    .dna-title {
        font-family: 'PP Radio Grotesk';
        font-weight: 700;
        font-size: 57px;
        line-height: 69px;
        display: flex;
        justify-content: center;
        color: #404733;
    }

    .dna-title span {
        padding-left: 10px;
        background-image: url("{{ 'our-story-dna-section-swoosh.png' | asset_url }}");
    }

    .dna-section-text {
        padding: 10px 0 30px;
        font-family: 'PP Radio Grotesk';
        font-weight: 400;
        font-size: 34px;
        line-height: 41px;
        display: flex;
        justify-content: center;
        text-align: center;
        text-transform: capitalize;
        color: #404733;
    }

    .text-about {  
        position: relative;
        z-index: 1;
        max-width: 472px;
        font-family: 'DM Sans';
        font-weight: 400;
        font-size: 18px;
        line-height: 26px;
        letter-spacing: -0.02em;
        color: #000000;

    }

    @media screen and (max-width: 1440px) {
        .dna-img {
            max-width: 62vw;
        }
    }


    @media screen and (max-width: 768px) {
        .dna-section {
            max-height: unset;
        }
        .dna-img {
            max-width: unset;
            top: 28vw;
            right: -40vw
        }

       .dna-title span {
            margin-left: 1vw;
        }

     
        .dna-title {
            font-size: 13vw;
            line-height: 1.2em;
        }

        .text-about {
            max-width: unset;
            padding-top: 80vw;
        }

    
    }

    @media screen and (max-width: 740px) {
        .dna-img {
           
            right: -33vw
        }

    }

    @media screen and (max-width: 700px) {
        .dna-img {

            right: -39vw
        }

        .text-about {  
            padding-top: 86vw;
        }


    }

    
    @media screen and (max-width: 650px) {
        .dna-img {

            right: -50vw
        }

        .text-about {  
            padding-top: 90vw;
        }


    }

    @media screen and (max-width: 600px) {
        .dna-img {
            width: 150vw;
            right: -40vw
        }

        .text-about {  
            padding-top: 85vw;
        }


    }

    @media screen and (max-width: 516px) {
        .dna-img {
            top:36vw;
        }

        .text-about {  
            padding-top: 80vw;
        }

    }

    @media screen and (max-width: 420px) {
        .dna-img {
            top:40vw;
        }

    }

    @media screen and (max-width: 393px) {
        .dna-img {
            top:45vw;
        }

    }
</style>







{% schema %}
{
    "name": "Dna T&I",
    "tag": "section",
    "class": "dna-t-i",
    "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
    },
    "settings": [{
            "type": "color",
            "id": "bg_color",
            "label": "Background Color"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
        },
        {
            "type": "text",
            "id": "title",
            "label": "Title"
        },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
        {
            "type": "richtext",
            "id": "main_content",
            "label": "Content"
        }
       
    ],
    "presets": [{
        "name": "Dna T&I"
    }]
}
{% endschema %}