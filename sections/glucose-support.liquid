{% render 'new-year-hero-banner-content-curalin', mainTitle: "curalin", subTitle: "Natural Blood Sugar Support Supplement", ctaButtonLink: "/collections", ctaTitle: "SHOP NOW" %}
<div class="support-page offset-top">
    <div class="container">
        <div class="mini-wrap">
            <div class="advantages-section">
                <div class="sub-title">
                    <h2>Curalin Powerfully Helps</h2>
                </div>
                <div class="advantages-wrap">
                    {% assign cura_powers = 'new-year-group-1.png*Supports healthy pancreatic function
                    |new-year-group-2.png*Reduces cravings for sugars & carbs
                    |new-year-group-3.png*Promotes high daily energy levels
                    |new-year-group-4.png*Supports pancreas, liver, and kidney health
                    |new-year-group-5.png*Promotes balanced blood glucose levels
                    |new-year-group-6.png*Promotes healthy weight loss
                    ' | split: '|' %}
                    <ul>


                        {% for cura_power in cura_powers %}
                            <li class="advantage-content">
                            <img src="{{ cura_power | split: '*' | first | asset_url }}" width="128" height="112" alt="icon-wrap" loading="lazy">
                                <div class="name">
                                <p>{{ cura_power | split: '*' | last }}</p>
                                </div>
                                </li>
                        {% endfor %}
                        </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="story-section">
        <div class="container">
            <div class="mini-wrap">
                <div class="sub-title">
                    <h2>{{ section.settings.wht_titl }}</h2>
                </div>

                {% if section.settings.wht_desc != blank %}
                <div class="text">
                    <p>{{section.settings.wht_desc}}</p>
                </div>
                {% endif %}
                <div class="badges">
                    <ul>
                        {% for i in (1..6) %}
                        <li class="wht_img">
                            {% assign imgUrl = "wht_img-" | append: i | append: ".png" %}
                            <img src="{{ imgUrl | file_url }}" alt="" loading="lazy">
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

{% render 'start-healthier-life', ctaButtonLink: "/collections", ctaTitle: "SHOP NOW" %}
{% render 'powerful-natural-ingredients' %}  
<div class="support-page bottom-line">
  <div class="container">
    <div class="white-bg">
      <div class="mini-wrap">
        <div class="changing-experiences">
          <div class="sub-title">
            <h2 class="d-desktop">{{ section.settings.clnt_titl }}</h2>
            <h3 class="d-mobile">{{ section.settings.clnt_mbltitl }}</h3>
          </div>
          <div class="quote-slider">
            <div class="swiper">
              <div class="swiper-wrapper">
                {% for block in section.blocks %}
                {% if block.type == 'our_clients' %}
                <div class="swiper-slide">
                  <div class="quote-card">
                    <blockquote>
                      <p>{{ block.settings.quot_descript }}</p>
                    </blockquote>
                    <div class="quote-info">
                      <div class="quote-author">
                        <p>{{ block.settings.authr_name }}</p>
                      </div>
                      <div class="quote-rating">
                        <p>
                          <span class="{{block.settings.quor_ratingone}}"></span>
                          <span class="{{block.settings.quor_ratingtwo}}"></span>
                          <span class="{{block.settings.quor_ratingthree}}"></span>
                          <span class="{{block.settings.quor_ratingfoue}}"></span>
                          <span class="{{block.settings.quor_ratingfive}}"></span>
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
                {% endif %}
                {% endfor %}

              </div>
              <div class="slide-control">
                <div class="prev-slide2"><span class="icon-arrow"></span></div>
                <div class="next-slide2"><span class="icon-arrow"></span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="customer-success">
    <div class="container">
      <div class="mini-wrap">
        <div class="intro-text">
          <div class="sub-title">
            <h3>{{section.settings.custm_titl}}</h3>
          </div>
        </div>
        <div class="success-list">
          <ul>
            {% assign contr = 0 %}
            {% for block in section.blocks %}
            {% if block.type == 'customer_success' %}
            <li class="success-content-{{ contr }}">
              <div class="title">
                <h4>{{block.settings.cstmr_sbtitl}}</h4>
              </div>
              <div class="line">
                <div class="percentage">
                  <p>{{block.settings.cstmr_percen}}</p>
                </div>
                <div class="data">
                  <span style="{{block.settings.percen_color}}"></span>
                </div>
              </div>
            </li>

            {% assign contr = contr | plus : 1 %}
            {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="white-bg">
      <div class="mini-wrap">
        <div class="feature-info">
         
          <div class="img-wrap">
            <span><img src="{{ 'curalin-homepage-bottle-global.png' | asset_url }}" width="606" height="538" alt="" loading="lazy"></span>
          </div>
         
          <div class="intro-text">
            <div class="sub-title">
              <h3>{{section.settings.mntain_titl}}</h3>
              <p>{{section.settings.mntain_desc}}</p>
            </div>
            <div class="btn">
              <a href="{{section.settings.mntain_btnlink}}" class="main-btn">{{section.settings.mntainbtn_titl}}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .slide-control {
    display: flex;
    justify-content: center;
    padding-top: 20px;
  }
</style>

<script>
  quoteSlider = new Swiper(".quote-slider .swiper", {
    slidesPerView: 2,
    spaceBetween: 0,
    grabCursor: true,
    autoHeight: true,
    loop: true,
    navigation: {
      nextEl: ".next-slide2",
      prevEl: ".prev-slide2",
      disabledClass: 'disabled'
    },
    breakpoints: {
      0: {
        slidesPerView: 1
      },
      630: {
        slidesPerView: 2,
        centeredSlides: false
      },
      992: {
        slidesPerView: 3,
        centeredSlides: true
      }
    }
  });
</script>

