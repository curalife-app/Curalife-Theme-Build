
 <div class="sale-banner">
  <div class="container">
    <div class="logo-wrapper">
     <img class="logo" src="{{ section.settings.bg_image | image_url }}" width="164" height="45" alt="logo">
    </div>

    <div class="cta-wrapper">
   
      <div class="twenty-percent-off">
            <div class="up-to">
                UP TO
            </div>
            <div class="off"> 25% OFF</div>
            <div class="twenty">25</div>
            <div class="percent-off">
                <div class="percent">%</div>
                <div class="off-mobile">OFF</div>
            </div>
        </div>
   
       
    
      <a class="main-btn" id='main-cta-btn' href="{{ section.settings.button_link }}">{{ ctaButtonTitle }}</a>
    </div>
  </div>
</div>

<style>
  section {
    padding: unset !important;
  }
  .sale-banner {
    background-image: url("{{ 'sticky-banner.png' | asset_url }}");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;

  }
  .twenty-percent-off {
    display: flex;
  }

  .up-to {
    width: 25px;
    height: 40px;
    font-family: 'PP Radio Grotesk';
    font-weight: 400;
    font-size: 16px;
    line-height: 20px;
  }

  .off {
    margin-left: 10px;
    height: 40px;
    font-family: 'PP Radio Grotesk';
    font-weight: 700;
    font-size: 50px;
    line-height: 20px;
    display: flex;
    align-items: center;
  }

  .twenty {
    display: none;
  }

  .percent-off {
    display: none;
  }

  @media screen and (max-width: 768px) {

    .up-to {
      margin-top: 10px;
      width: 20px;
      height: 15px;
      font-weight: 400;
      font-size: 12px;
      line-height: 12px;
    }

    .off {
      display: none;
    }

    .twenty {
      display: flex;
      width: 55px;
      height: 47px;
      font-family: 'PP Radio Grotesk';
      font-weight: 700;
      font-size: 40px;
      line-height: 40px;
    }

    .percent-off {
      display: flex;
      margin-left: -10px;
    }

    .percent {
      height: 47px;
      margin-top: -5px;
      font-family: 'PP Radio Grotesk';
      font-weight: 700;
      font-size: 40px;
    
      }
      .off-mobile {        
          font-family: 'PP Radio Grotesk';
          font-weight: 700;
          font-size: 40px;
          margin-top: -4px;
      }
    }

</style>



<style>
  
  .sale-banner {
    position: fixed;
  }

  .sale-banner.{{ instance_id }} img.logo {
    display: {% if desktopContent contains 'logo' %}block{% else %}none{% endif %};
  }

  .sale-banner.{{ instance_id }} p.title {
    display: {% if desktopContent contains 'title' %}block{% else %}none{% endif %};
    font-size:{% if longTitle %}clamp(32px, 3vw, 50px){% else %}clamp(38px, 4vw, 50px){% endif %};
    padding-bottom:{% if longTitle %}7px{% else %}20px{% endif %};
    left:{% if longTitle %}62%{% else %}50%{% endif %};
  }

  .sale-banner.{{ instance_id }} .off-container {
    display: {% if desktopContent contains 'cta' %}flex{% else %}none{% endif %};
  }

  .sale-banner.{{ instance_id }} .off-container {
    display: {% if desktopContent contains 'cta' %}flex{% else %}none{% endif %};
  }

  {% unless desktopContent contains 'cta-button' %}
    .sale-banner.{{ instance_id }} a.main-btn {
      display: none;
    }
  {% endunless %}

  @media screen and (max-width: 768px) {
    

    {% if mobileContent contains ',' %}
      .sale-banner.{{ instance_id }} .container {
        gap: 3vw;
      }
    {% endif %}

    .sale-banner.{{ instance_id }} img.logo {
      display: {% if mobileContent contains 'logo' %}block{% else %}none{% endif %};
      width: {% unless logoFileName contains 'white' %}100%{% endunless %};
      max-width: {% if isLogoSmall %} 100px {% endif %};
    }

    .sale-banner.{{ instance_id }} p.title {
      display: {% if mobileContent contains 'title' %}block{% else %}none{% endif %};
      font-size: {% if isLogo %}7{% else %}9{% endif %}vw;
      {% if isLogo %}max-width: 50%;{% endif %}
    }

    .sale-banner.{{ instance_id }} .cta-wrapper {
      {% if isCTA %}width: 100%;{% endif %}
    }

    .sale-banner.{{ instance_id }} .off-container {
        display: {% if mobileContent contains 'cta' %}flex{% else %}none{% endif %};
    }

    .sale-banner.{{ instance_id }} a.main-btn {
      display: {% if mobileContent contains 'cta-button' %}block{% else %}none{% endif %};
    }
  }
</style>

<style>
  .sale-banner {
    box-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
    transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    overflow: hidden;
    width: 100%;
    z-index: 20;
    min-height: 80px;
  }

  .sale-banner.hidden {
    display: none;
  }

  .sale-banner .container {
    position: relative;
    min-height: 80px;
    display: flex;
    justify-content: {% if isOnlyLogo %} center {% else %} space-between {% endif %};
    align-items: center;
  }

  .sale-banner img.logo {
    object-fit: contain;
  }

  .sale-banner p.title {
    font-family: 'PP Radio Grotesk';
    color: #ffffff;
    padding: 10px 0;
    margin: unset;
    text-align: center;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: max-content;
    line-height: 1.2em;
  }

  .sale-banner .cta-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    color: #404733;
  }

  .sale-banner .off-container {
    justify-content: center;
    align-items: center;
    font-family:'PP Radio Grotesk';
    gap: 10px;
    color: {% unless isFlash %} white {% endunless %};
  }

 

  .sale-banner .up-to {
    font-size: {% unless isFlash %} 25px{% endunless %};
  }

  .sale-banner .percents-off {
    margin-right: 10px;
    font-size: {% if isFlash %}clamp(20px, 2vw, 35px) {% else %} 35px {% endif %};
    font-weight: bold;
    text-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
  }

  .sale-banner a.main-btn {
    font-size: 26px;
    padding: 10px 40px;
    color: white;
    background: var(--dark-green);
    border-radius: 6px;
    box-shadow: 0px 5px 12px rgba(0, 0, 0, 0.15);
  }

  @media screen and (max-width: 768px) {
    .sale-banner {
      top: 0;
      {% if mobileContent == 'none' %}display: none;{% endif %}
    }
    .sale-banner {
      min-height: 60px;
    }

    .sale-banner .container { 
      min-height: 60px;
    }
  
    .sale-banner p.title {
      position: unset;
      transform: unset;
      padding-bottom: 10px;
    }

    .sale-banner .cta-wrapper {
      gap: 1vw;
    }

    .sale-banner .off-container {
      gap: unset;
    }

    .sale-banner .up-to {
      font-size:{% unless isFlash %} 4vw{% endunless %};
    }

    .sale-banner .percents-off {
      display:flex;
      justify-content: center;
      margin-right: unset;
      font-size: {% if isFlash %} 4vw {% else %} 6vw {% endif %};
      line-height: {% if isFlash %} 4vw {% else %} 6vw {% endif %};
    }

    .sale-banner a.main-btn {
      text-align:center;
      font-size: 4vw;
      padding: 3vw;
      height: 10vw;
    }
  }

  @media screen and (max-width: 425px) {
    .up-to {
      margin-top: {% if isFlash %} 2vw{% endif %};
      width: {% if isFlash %} 5vw{% endif %};
      font-size: {% if isFlash %}3vw{% endif %};
      line-height: {% if isFlash %}3vw{% endif %};
    }
  }
</style>

{% if isHidden %}
  <script>
    let queryParam = window.location.search;

    if (queryParam.includes('sale=')) {
      $('.sale-banner').toggleClass('hidden');
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "Header Easter",
  "tag": "section",
  "class": "header-easter",
  "disabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image on Mobile"
    },
    {
      "type": "text",
      "id": "small_title",
      "label": "Small Title"
    },
    {
      "type": "text",
      "id": "big_title",
      "label": "Big Title"
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Content Align on Mobile",
      "options": [
        {
          "value": "start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "end",
          "label": "Bottom"
        }
      ],
      "default": "start"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color"
    },
    {
      "type": "checkbox",
      "id": "is_title_right",
      "label": "Place Title Right"
    },
    {
      "type": "checkbox",
      "id": "is_title_shadow",
      "label": "Title Shadow"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_title",
      "label": "Button Title"
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_link2",
      "label": "Button Link 2"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color"
    },
    {
      "type": "color",
      "id": "button_title_color",
      "label": "Button Title Color"
    }
  ],
  "presets": [
    {
      "name": "Header Easter"
    }
  ]
}
{% endschema %}
  